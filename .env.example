# Public site URL (used for canonical URL, OG metadata)
NEXT_PUBLIC_SITE_URL=https://crpc.example.com

# Pricing parameters — V = a × (J − b)^c
# Leave commented to use the defaults in src/config/constants.ts.
# Uncomment + set to override at deploy time without code changes.
# Current defaults (2026-05-24): a=9.215e-6, b=-1e6, c=0.5056
# NEXT_PUBLIC_PRICE_PARAM_A=0.000009215
# NEXT_PUBLIC_PRICE_PARAM_B=-1000000
# NEXT_PUBLIC_PRICE_PARAM_C=0.5056

# CRPC contract address (already confirmed)
NEXT_PUBLIC_CRPC_CONTRACT_ADDRESS=0x61c4d061149fd7a559e021c8dffcfb364ffded1a

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# External APIs
ETHERSCAN_API_KEY=
COINGECKO_API_KEY=

# DigiFinex (public endpoints only; no API key needed for ticker)
DIGIFINEX_SYMBOL=crpc_usdt
