# Public site URL (used for canonical URL, OG metadata)
NEXT_PUBLIC_SITE_URL=https://crpc.example.com

# Pricing parameters — V = a × (J − b)^c
# Leave commented to use the defaults in src/config/constants.ts.
# Uncomment + set to override at deploy time without code changes.
# Current defaults (2026-05-24): a=9.215e-6, b=-1e6, c=0.5056
# NEXT_PUBLIC_PRICE_PARAM_A=0.000009215
# NEXT_PUBLIC_PRICE_PARAM_B=-1000000
# NEXT_PUBLIC_PRICE_PARAM_C=0.5056

# CRPC contract address (already confirmed)
NEXT_PUBLIC_CRPC_CONTRACT_ADDRESS=0x61c4d061149fd7a559e021c8dffcfb364ffded1a

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# External APIs
ETHERSCAN_API_KEY=
COINGECKO_API_KEY=

# DigiFinex public endpoints (market data ticker)
DIGIFINEX_SYMBOL=crpc_usdt

# DigiFinex authenticated trading (used by /api/admin/digifinex-order).
# Two accounts; cron buy1/sell1 → account 1, buy2/sell2 → account 2.
# Create API keys at digifinex.com → account → API. Grant trade-only (no withdrawal).
DIGIFINEX_API_KEY_1=
DIGIFINEX_API_SECRET_1=
DIGIFINEX_API_KEY_2=
DIGIFINEX_API_SECRET_2=

# Shared secret between Supabase pg_cron and the Vercel endpoint.
# Generate with: openssl rand -hex 32
# Store the SAME value in:
#   1. Vercel env var (here)
#   2. Supabase Vault: select vault.create_secret('THE_VALUE', 'digifinex_cron_secret');
DIGIFINEX_CRON_SECRET=

# ----- Vowcha daily ingest (used by /api/ingest/vowcha-daily) -----
# API token from admin.vowcha.net (Bearer auth for vowcha API).
VOWCHA_API_TOKEN=

# Shared secret between Supabase pg_cron and the ingest endpoint.
# Generate with: openssl rand -hex 32. Same value also goes into Supabase Vault
# as the secret name `vowcha_ingest_secret`.
VOWCHA_INGEST_SECRET=
